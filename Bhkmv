    elseif input.KeyCode == _G.BindGun then grabGunAction()
    end
end)

-- ESP
local function applyPlayerESP(p)
    if p == lp then return end

    local function setup(char)
        if not char then return end
        local highlight = char:FindFirstChild("ExodusHighlight") or Instance.new("Highlight", char)
        highlight.Name = "ExodusHighlight"
        highlight.FillTransparency = 0.5

        local head = char:WaitForChild("Head", 5)
        local bill = head:FindFirstChild("ExodusBill") or Instance.new("BillboardGui", head)
        bill.Name = "ExodusBill"
        bill.Size = UDim2.new(0, 100, 0, 50)
        bill.AlwaysOnTop = true
        bill.ExtentsOffset = Vector3.new(0, 3, 0)

        local label = bill:FindFirstChild("ExodusLabel") or Instance.new("TextLabel", bill)
        label.Name = "ExodusLabel"
        label.Size = UDim2.new(1, 0, 1, 0)
        label.BackgroundTransparency = 1
        label.Font = Enum.Font.GothamBold
        label.TextSize = 14
        label.TextStrokeTransparency = 0
        label.TextStrokeColor3 = Color3.new(0,0,0)

        task.spawn(function()
            while char and char.Parent do
                if _G.ESPEnabled then
                    local isM = p.Backpack:FindFirstChild("Knife") or char:FindFirstChild("Knife")
                    local isS = p.Backpack:FindFirstChild("Gun") or char:FindFirstChild("Gun")

                    highlight.Enabled = true
                    bill.Enabled = true

                    if isM then
                        highlight.FillColor = Color3.new(1,0,0)
                        label.Text = "MURDERER\n▼"
                        label.TextColor3 = Color3.new(1,0,0)
                    elseif isS then
                        highlight.FillColor = Color3.new(0,0,1)
                        label.Text = "SHERIFF\n▼"
                        label.TextColor3 = Color3.new(0,0,1)
                    else
                        highlight.FillColor = Color3.new(0,1,0)
                        label.Text = "▼"
                        label.TextColor3 = Color3.new(0,1,0)
                    end
                else
                    highlight.Enabled = false
                    bill.Enabled = false
                end
                task.wait(0.5)
            end
        end)
    end

    p.CharacterAdded:Connect(setup)
    if p.Character then setup(p.Character) end
end

for _, v in pairs(Players:GetPlayers()) do applyPlayerESP(v) end
Players.PlayerAdded:Connect(applyPlayerESP)

-- Auto Features
local function ResetCharacterPhysics()
    if lp.Character and lp.Character:FindFirstChild("Humanoid") then
        local hum = lp.Character.Humanoid
        if layTrack then layTrack:Stop() end
        hum.JumpPower = _G.DesiredJump
        hum.WalkSpeed = _G.DesiredSpeed
        hum:SetStateEnabled(Enum.HumanoidStateType.GettingUp, true)
        hum:ChangeState(Enum.HumanoidStateType.GettingUp)
    end
end

